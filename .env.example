# MemeVaultProject environment variable overrides
# Copy this file to .env.local and uncomment the variables you want to set.
# Settings not set here are stored in the SQLite database and editable from the Settings page.

# ── Storage ───────────────────────────────────────────────────────────────────

# Base directory for all app data: database, auto-managed binaries, and downloaded media.
# Defaults to ~/.memevaultproject/
# MEMEVAULTPROJECT_DATA_DIR=/home/user/.memevaultproject

# Absolute path where downloaded and uploaded files will be saved.
# Defaults to $MEMEVAULTPROJECT_DATA_DIR/media
# MEMEVAULTPROJECT_DOWNLOAD_PATH=/home/user/.memevaultproject/media

# ── Downloader options ────────────────────────────────────────────────────────

# Extra arguments appended to every yt-dlp invocation (e.g. --no-playlist)
# MEMEVAULTPROJECT_YTDLP_EXTRA_ARGS=

# Extra arguments appended to every gallery-dl invocation
# MEMEVAULTPROJECT_GALLERYDL_EXTRA_ARGS=

# Absolute path to a custom yt-dlp binary (leave unset to use the auto-managed binary)
# MEMEVAULTPROJECT_YTDLP_BIN=/usr/local/bin/yt-dlp

# Absolute path to a custom gallery-dl binary (leave unset to use the auto-managed binary)
# MEMEVAULTPROJECT_GALLERYDL_BIN=/usr/local/bin/gallery-dl

# Absolute path to a custom ffmpeg binary (leave unset to use the auto-managed binary)
# MEMEVAULTPROJECT_FFMPEG_BIN=/usr/bin/ffmpeg

# ── Sharing ───────────────────────────────────────────────────────────────────

# Base URL used in share link Open Graph embeds (e.g. https://vault.example.com).
# Required for OG previews to work correctly behind a reverse proxy.
# MEMEVAULTPROJECT_SHARE_BASE_URL=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity level: error, warn, info (default), or debug.
# Set to debug to see all subprocess output from yt-dlp and gallery-dl.
# MEMEVAULTPROJECT_LOG_LEVEL=info

# ── API keys ──────────────────────────────────────────────────────────────────

# Legacy single API key for /api/v1/* endpoints (deprecated — use the API Keys settings page instead).
# Still accepted if set, but new installs should manage keys via the UI.
# MEMEVAULTPROJECT_API_KEY=

# ── OIDC / OpenID Connect authentication (optional) ───────────────────────────

# Secret used to sign and encrypt session tokens. Required when OIDC is enabled.
# Generate with: openssl rand -base64 32
# AUTH_SECRET=

# Canonical URL of your app. Required in production/Docker; inferred in development.
# AUTH_URL=https://vault.example.com

# OIDC provider discovery URL (the base issuer URL, not the /.well-known path).
# Setting this (along with CLIENT_ID and CLIENT_SECRET) enables authentication.
# Examples: https://auth.example.com/application/o/memevault/  (Authentik)
#           https://keycloak.example.com/realms/myrealm        (Keycloak)
# MEMEVAULTPROJECT_OIDC_ISSUER=

# Client ID and secret from your OIDC provider.
# Register redirect URI: https://your-domain.com/api/auth/callback/oidc
# MEMEVAULTPROJECT_OIDC_CLIENT_ID=
# MEMEVAULTPROJECT_OIDC_CLIENT_SECRET=
